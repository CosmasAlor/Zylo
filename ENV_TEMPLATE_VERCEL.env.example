# Environment Variables Template for Vercel Deployment
# Fill in these values and add them to Vercel Project Settings → Environment Variables

# ============================================
# DATABASE (from Supabase)
# ============================================
# Format: postgresql://postgres.[PROJECT_ID]:[PASSWORD]@aws-0-[region].pooling.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=

# ============================================
# NEXTAUTH CONFIGURATION
# ============================================
# Your Vercel deployment URL (will be like: https://your-project-name.vercel.app)
NEXTAUTH_URL=

# Same as NEXTAUTH_URL
NEXT_PUBLIC_APP_URL=

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=

# ============================================
# ADMIN CREDENTIALS
# ============================================
# Email for admin login
ADMIN_EMAIL=

# Strong password for admin login (use password manager)
ADMIN_PASSWORD=

# ============================================
# INSTRUCTIONS
# ============================================
# 1. Fill in all values above
# 2. Go to Vercel Dashboard https://vercel.com/dashboard
# 3. Select your Zylo project
# 4. Go to Settings → Environment Variables
# 5. Add each variable one by one
# 6. Set them for: Production, Preview, Development (or all)
# 7. Redeploy: Deployments → Promote to Production
# 
# DO NOT COMMIT THIS FILE WITH VALUES FILLED IN
# Keep this as a reference template only
