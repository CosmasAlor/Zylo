generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Appointment {
  id            String            @id @default(cuid())
  fullName      String
  phone         String
  email         String?
  service       String
  preferredDate DateTime
  preferredTime String
  notes         String?
  status        AppointmentStatus @default(PENDING)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

model LogEntry {
  id        String   @id @default(cuid())
  type      LogType
  route     String?
  message   String
  payload   Json?
  stack     String?
  createdAt DateTime @default(now())
}

enum LogType {
  EVENT
  ERROR
  WARNING
}
  
model ModuleConfig {
  id        String   @id @default(cuid())
  name      String   @unique
  isEnabled Boolean  @default(true)
  updatedAt DateTime @updatedAt
}

model ContentBlock {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
}

model BlogPost {
  id         String   @id @default(cuid())
  slug       String   @unique
  title      String
  content    Json     // Store as Rich Text JSON or blocks
  excerpt    String?
  coverImage String?
  published  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model MediaItem {
  id        String   @id @default(cuid())
  url       String   // Relative path to /public/uploads/
  filename  String
  fileType  String
  size      Int
  createdAt DateTime @default(now())
}

model GalleryItem {
  id         String   @id @default(cuid())
  beforeUrl  String
  afterUrl   String
  caption    String?
  order      Int      @default(0)
  createdAt  DateTime @default(now())
}
